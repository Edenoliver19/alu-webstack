#!/bin/bash
# 0-world_wide_web
# Audits subdomains for a given domain using dig and awk
# Usage: ./0-world_wide_web domain [subdomain]

ignore_sc2086() {
  : # Placeholder to ignore shellcheck SC2086
}

get_subdomain_info() {
  local domain=$1
  local subdomain=$2
  local fqdn="${subdomain}.${domain}"
  local dig_output
  dig_output=$(dig $fqdn | awk '/^;; ANSWER SECTION:/ {getline; print $0}')
  if [[ -n "$dig_output" ]]; then
    local record_type=$(echo $dig_output | awk '{print $4}')
    local destination=$(echo $dig_output | awk '{print $5}')
    echo "The subdomain $subdomain is a $record_type record and points to $destination"
  fi
}

main() {
  local domain=$1
  local subdomain=$2
  if [[ -z "$domain" ]]; then
    echo "Usage: $0 domain [subdomain]"
    exit 1
  fi
  if [[ -z "$subdomain" ]]; then
    for s in www lb-01 web-01 web-02; do
      get_subdomain_info "$domain" "$s"
    done
  else
    get_subdomain_info "$domain" "$subdomain"
  fi
}

main "$@"
