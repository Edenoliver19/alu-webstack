global
    log /dev/log local0
    daemon

defaults
    log global
    mode http
    option httplog
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend https_front
    bind *:443 ssl crt /etc/haproxy/certs/www.pem
    default_backend web_servers

backend web_servers
    balance roundrobin
    server web-01 54.147.35.15:80 check
    server web-02 54.211.12.67:80 check
